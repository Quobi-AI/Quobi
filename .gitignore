# ---- secrets (NEVER commit) ----
.env
*.env
**/.env
*.key
local.properties

# ---- python (daemon) ----
__pycache__/
*.pyc
.venv/
*.egg-info/

# ---- build artifacts ----
dist/
build/
# cmake out-of-source dirs (e.g. core/build-host)
build-*/
*.so
*.o
*.a
*.rlib
*.rmeta

# ---- node / tauri frontend ----
node_modules/
.vite/

# ---- rust (tauri) ----
target/

# ---- android / gradle ----
.gradle/
*.apk
*.aab
.cxx/

# ---- models & large artifacts (downloaded, not source) ----
*.gguf
*.safetensors
models/
*.tar.gz
quobi-cleanup-bundle/

