core/third_party/llama.cpp/build/

# ---- os / editor ----
.DS_Store
*.swp

# ---- packaged app (build artifact) ----
*.AppImage

# Tauri bundled sidecars (built artifacts, staged at build time)
voice-type-desktop/src-tauri/linuxbundle/
voice-type-desktop/src-tauri/winbundle/

# --- public-launch hygiene ---
voice-type-android/
voice-type/training/data/
.claude/
dist/
*.tar.gz
.venv/

